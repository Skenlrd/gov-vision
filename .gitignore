# ============================================
# GovVision - Single Root .gitignore
# ============================================

# ============================================
# ENVIRONMENT VARIABLES (NEVER COMMIT SECRETS)
# ============================================
.env
.env.local
.env.*.local
server/.env
ml_service/.env
client/.env

# Config folder (contains env files)
config/

# ============================================
# NODE / JAVASCRIPT
# ============================================
# Dependencies
node_modules/

# Build outputs
dist/
dist-ssr/
build/
server/dist/
client/dist/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Package locks (optional - some teams commit these)
# package-lock.json
# yarn.lock

# ============================================
# PYTHON
# ============================================
# Virtual environments
.venv/
env/
venv/
ENV/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Jupyter
.ipynb_checkpoints/

# ============================================
# ML SERVICE
# ============================================
# Model artifacts
ml_service/models/*.pkl
ml_service/models/*.joblib

# ============================================
# SERVER SPECIFIC
# ============================================
# Generated reports
server/generated_reports/
*.xes
server/Dataset/*.xes
server/Dataset/*.csv

# ============================================
# CLIENT SPECIFIC (Vite/React)
# ============================================
*.local
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# EDITORS / IDES
# ============================================
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# ============================================
# OS FILES
# ============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini
Thumbs.db

# ============================================
# TESTING / COVERAGE
# ============================================
.coverage
.pytest_cache/
.mypy_cache/
coverage.xml
htmlcov/

# ============================================
# PROJECT SPECIFIC
# ============================================
# Testing notes
TestNotes.md

# Archived files
redundant/

